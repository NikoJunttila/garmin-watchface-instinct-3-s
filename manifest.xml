<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!-- App definition: id, type, name, entry class, and target devices. -->
<iq:manifest version="3" xmlns:iq="http://www.garmin.com/xml/connectiq">
    <iq:application
        id="f21596d3ee264cecbdadc64f883566d7"
        type="watchface"
        name="@Strings.AppName"
        entry="NordicApp"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="6.0.0">

        <!-- Watches this builds for. The Instinct 3 Solar (176x176, 1-bit MIP,
             semi-octagon). The single 45mm product id covers both 45mm and 50mm. -->
        <iq:products>
            <iq:product id="instinct3solar45mm"/>
        </iq:products>

        <!-- System permissions. SensorHistory is required to read Body Battery
             (SensorHistory.getBodyBatteryHistory). The other stats shown —
             steps, heart rate, battery — need no permission. -->
        <iq:permissions>
            <iq:uses-permission id="SensorHistory"/>
        </iq:permissions>

        <!-- Supported languages. -->
        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>

        <!-- Shared code libraries (none used). -->
        <iq:barrels/>

    </iq:application>
</iq:manifest>
